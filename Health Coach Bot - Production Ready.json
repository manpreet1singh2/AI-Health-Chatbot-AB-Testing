    {
      "parameters": {
        "jsCode": "const msg = $input.item.json.message;\nconst userId = String(msg.from.id);\nconst userName = msg.from.first_name || msg.from.username || 'User';\nconst userMessage = msg.text || '';\nconst chatId = String(msg.chat.id);\n\n// Detect command\nlet command = 'message';\nif (userMessage.startsWith('/start')) command = 'start';\nelse if (userMessage.startsWith('/addmeal')) command = 'addmeal';\nelse if (userMessage.startsWith('/viewmeals')) command = 'viewmeals';\nelse if (userMessage.startsWith('/editmeal')) command = 'editmeal';\nelse if (userMessage.startsWith('/deletemeal')) command = 'deletemeal';\n\nreturn [{\n  json: {\n    userId,\n    userName,\n    userMessage,\n    chatId,\n    command,\n    sessionId: 'telegram_' + userId,\n    chatInput: userMessage\n  }\n}];"
      },
      "id": "0cf127f8-60b9-4361-b213-f1e9355eb4bd",
      "name": "Prepare AI Context1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
