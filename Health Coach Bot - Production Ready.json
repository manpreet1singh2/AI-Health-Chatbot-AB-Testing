    {
      "parameters": {
        "jsCode": "const meals = $input.all();\nconst chatId = $('Prepare AI Context1').item.json.chatId;\n\nif (!meals || meals.length === 0) {\n  return [{ json: { chatId, text: '📭 Koi meal log nahi hai abhi!\\n\\nShuru karein? /addmeal use karo! 🍽️' } }];\n}\n\nlet msg = '📋 *Aapki Meal History:*\\n\\n';\nmeals.forEach((m, i) => {\n  const d = new Date(m.json.created_at);\n  const timeStr = d.toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' });\n  msg += `${i+1}. 🍽️ *${m.json.meal_name}*\\n   🆔 ID: \\`${m.json.id}\\`\\n   🕐 ${timeStr}\\n\\n`;\n});\n\nmsg += '_Edit karna hai? /editmeal use karo_\\n_Delete karna hai? /deletemeal use karo_';\n\nreturn [{ json: { chatId, text: msg } }];"
      },
      "id": "574e7222-ae7c-4a2e-9cbe-d2ad29c076a1",
