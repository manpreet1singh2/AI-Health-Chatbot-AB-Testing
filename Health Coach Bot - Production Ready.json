        "jsCode": "const statsigResult = $input.item.json;\nconst isTest = statsigResult.value === true;\nconst group = isTest ? 'test' : 'control';\nconst ctx = $('Prepare AI Context1').item.json;\n\nreturn [{\n  json: {\n    ...ctx,\n    group,\n    isTestGroup: isTest\n  }\n}];"
      },
