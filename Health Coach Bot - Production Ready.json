    {
      "parameters": {
        "jsCode": "const profiles = $input.all();\n\n// Safe access to context node\nconst ctxNode = $('Prepare AI Context1').first(); // Ensure it specifically selects the first item\nconst ctx = ctxNode ? ctxNode.json : {};\n\n// Default fallbacks\nconst chatInput = ctx.chatInput || '';\nconst sessionId = ctx.sessionId || '';\n\nreturn profiles.map(profile => {\n  return {\n    json: {\n      ...ctx,\n      userProfile: profile.json || {},\n      chatInput,\n      sessionId\n    }\n  };\n});"
      },
